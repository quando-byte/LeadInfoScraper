# Leadinfo API - Environment Variables
# Copy to .env and fill in your values (do not commit .env)

# Required: Leadinfo portal credentials
LEADINFO_EMAIL=your-email@example.com
LEADINFO_PASSWORD=your-password

# Optional: Restrict to UK companies only (default: true)
# LEADINFO_UK_ONLY=false

# Optional: Port (DigitalOcean sets PORT automatically)
# PORT=8080
